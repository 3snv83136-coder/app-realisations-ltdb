# Auth NextAuth
NEXTAUTH_SECRET=                    # openssl rand -base64 32
NEXTAUTH_URL=https://app-realisations.vercel.app

# Admins (identifiant seul, sans mot de passe)
AUTH_USER_1=admin

# Techniciens (identifiant:mot_de_passe_bcrypt[:uuid_technicien_supabase])
# Générer le hash : node -e "import('bcryptjs').then(b=>b.hash('MonMdp',10).then(console.log))"
# Si uuid absent, liaison auto au technicien dont le nom correspond à l'identifiant
AUTH_TECH_1=prenom.nom:$2b$10$remplacer_par_hash_bcrypt
# AUTH_TECH_2=jean:$2b$10$...:uuid-du-technicien-dans-supabase
AUTH_USER_4=                        # optionnel
AUTH_USER_5=                        # optionnel

# APIs
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Django LTDB
LTDB_API_URL=https://lestechniciensdudebouchage.fr
LTDB_PUBLISH_TOKEN=ruiQvAxSn5VL075j9WfTEL7ftvykTXkEgqBvbfFQfsw

# Resend (envoi email)
RESEND_API_KEY=re_...                # https://resend.com → API Keys
RESEND_FROM=Les Techniciens du Débouchage <contact@lestechniciensdudebouchage.fr>

# Supabase (CRM / historique / base de données)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...     # Project Settings → Data API → service_role

# ----- OAuth réseaux (Vercel : URIs en https://app-realisations-ltdb.vercel.app/api/oauth/...) -----
# YouTube (Google Cloud → credentials OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app-realisations-ltdb.vercel.app/api/oauth/google/callback

# Google Business Profile (autre client OAuth si besoin)
GMB_CLIENT_ID=
GMB_CLIENT_SECRET=
GMB_REDIRECT_URI=https://app-realisations-ltdb.vercel.app/api/oauth/gmb/callback

# Facebook + Instagram (Meta for Developers → même app)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://app-realisations-ltdb.vercel.app/api/oauth/facebook/callback

# TikTok (developers.tiktok.com)
TIKTOK_CLIENT_KEY=
