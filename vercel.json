{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "AWS_LAMBDA_JS_RUNTIME": "nodejs22.x"
  },
  "crons": [
    {
      "path": "/api/cron/compta-releve-alert",
      "schedule": "0 7 5 * *"
    },
    {
      "path": "/api/cron/controle-taux-paie",
      "schedule": "0 8 6 * *"
    },
    {
      "path": "/api/cron/avis-sms-relances",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/annuler-relances-factures-payees",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "app/api/generate-video/route.ts": {
      "maxDuration": 300,
      "memory": 3008
    },
    "app/api/cron/compta-releve-alert/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/controle-taux-paie/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/avis-sms-relances/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/annuler-relances-factures-payees/route.ts": {
      "maxDuration": 120
    },
    "app/api/interventions/[id]/generate-pdfs/route.ts": {
      "maxDuration": 120
    },
    "app/api/interventions/[id]/send-terrain-mail/route.ts": {
      "maxDuration": 120
    },
    "app/api/notify-rapport-facture/route.ts": {
      "maxDuration": 120
    }
  }
}
